# --- Government & market data APIs ---
MARKET_PRICE=your_data_gov_in_api_key_here
GEOAPIFY_KEY=your_geoapify_key_here
OPENWEATHER_KEY=your_openweather_api_key_here
GOVT_API_KEY=your_govt_api_key_here

# --- Image hosting ---
IMAGE_KIT_ENDPOINT=your_imagekit_endpoint_here
IMAGE_KIT_PUBLIC_KEY=your_imagekit_public_key_here
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# --- Ollama (local or remote LLM / vision) ---
OLLAMA_VISION_URL=http://localhost:11434/api/generate
OLLAMA_CROP_URL=http://localhost:11434
OLLAMA_LLM_URL=http://localhost:11434
OLLAMA_SERVER_URL=http://localhost:11434

# --- ASR (optional IndicConformer server) ---
VAKYANSH_ASR_URL=http://localhost:8001/asr

# --- Gmail price alerts ---
ALERT_SENDER_EMAIL=your_sender_email_here
ALERT_APP_PASSWORD=your_gmail_app_password_here

# --- OCR tooling (machine-specific; leave blank if Tesseract/Poppler are on PATH) ---
TESSERACT_CMD=
POPPLER_PATH=

# --- GPS / location fallbacks when user location is unavailable ---
DEFAULT_FALLBACK_CITY=Pune
DEFAULT_FALLBACK_STATE=Maharashtra
